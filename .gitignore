# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/

# Virtual envs (large; machine-specific; never ship)
.venv/
venv/
env/

# OS / IDE
.DS_Store
.vscode/
.idea/

# Detection caches saved next to source videos (regenerable)
*.det_cache.pkl

# Local clip manifest (each user's video paths differ; ship the example only)
configs/clips.json

# Background-job pid files dropped by long-running scripts
*.pid
